<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/cm/css/base.css" type="text/css"?>
<?xml-stylesheet href="/cm/dam/css/dam.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare"
    xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate/>
        <w2:MSA/>
        <xf:model>
            <w2:dataCollection baseNode="map">
                <w2:dataList id="dlVersion" baseNode="list" repeatNode="map">
                    <w2:columnInfo>
                        <w2:column id="CHK" name="CHK" dataType="text"/>
                        <w2:column id="ASSET_ID" name="ASSET_ID" dataType="text"/>
                        <w2:column id="ICON" name="ICON" dataType="text"/>
                        <w2:column id="FILE_NM" name="FILE_NM" dataType="text"/>
                        <w2:column id="FILE_TYPE" name="FILE_TYPE" dataType="text"/>
                        <w2:column id="FILE_SIZE" name="FILE_SIZE" dataType="text"/>
                        <w2:column id="STATUS" name="STATUS" dataType="text"/>
                        <w2:column id="PREVIEW_URL" name="PREVIEW_URL" dataType="text"/>
                        <w2:column id="TAGS" name="TAGS" dataType="text"/>
                        <w2:column id="CREATOR" name="CREATOR" dataType="text"/>
                        <w2:column id="RESOLUTION" name="RESOLUTION" dataType="text"/>
                        <w2:column id="UPLOAD_DT" name="UPLOAD_DT" dataType="text"/>
                    </w2:columnInfo>
                </w2:dataList>
            </w2:dataCollection>
            <w2:workflowCollection/>
        </xf:model>
        <w2:layoutInfo/>
        <w2:publicInfo method=""/>
        <script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function () {
    scwin.loadFolders();
};

scwin.callApi = function (url, callback) {
    var xhr = new XMLHttpRequest();
    xhr.open("GET", url, true);
    xhr.onreadystatechange = function () {
        if (xhr.readyState === 4) {
            if (xhr.status >= 200 && xhr.status < 300) {
                callback(JSON.parse(xhr.responseText || "{}"));
            }
        }
    };
    xhr.send();
};

scwin.loadFolders = function () {
    scwin.callApi("/api/dam/folders", function (folders) {
        if (!folders || folders.length === 0) {
            dlVersion.setJSON([]);
            return;
        }
        scwin._loadFirstFolderWithAssets(folders, 0);

        try {
            var tv = $p.getComponentById("trvVersionFolder");
            if (tv && typeof tv.expandAll === "function") { tv.expandAll(); }
        } catch (e) {}
    });
};

scwin._loadFirstFolderWithAssets = function (folders, index) {
    if (!folders || index >= folders.length) {
        dlVersion.setJSON([]);
        scwin._applyDetail(-1);
        return;
    }
    var folder = folders[index];
    var folderId = folder.folderId || folder.FOLDER_ID;
    scwin.callApi("/api/dam/assets?folderId=" + folderId, function (list) {
        if (list && list.length > 0) {
            scwin.loadAssets(folderId);
        } else {
            scwin._loadFirstFolderWithAssets(folders, index + 1);
        }
    });
};

scwin._formatFileSize = function (bytes) {
    var n = parseFloat(bytes || 0);
    if (!n || n <= 0) { return "0 B"; }
    var kb = 1024;
    var mb = kb * 1024;
    var gb = mb * 1024;
    if (n >= gb) { return (n / gb).toFixed(2) + " GB"; }
    if (n >= mb) { return (n / mb).toFixed(2) + " MB"; }
    if (n >= kb) { return (n / kb).toFixed(2) + " KB"; }
    return n + " B";
};

scwin.loadAssets = function (folderId) {
    scwin.callApi("/api/dam/assets?folderId=" + folderId, function (list) {
        var rows = [];
        for (var i = 0; i < (list || []).length; i++) {
            var item = list[i];
            rows.push({
                "CHK": "",
                "ASSET_ID": item.assetId,
                "ICON": item.fileExt ? item.fileExt.toUpperCase() : (item.fileType || ""),
                "FILE_NM": item.fileNm || "",
                "FILE_TYPE": item.fileType || "",
                "FILE_SIZE": scwin._formatFileSize(item.fileSize),
                "STATUS": item.status || "Draft",
                "PREVIEW_URL": item.previewUrl || "/cm/dam/images/preview/document.svg",
                "TAGS": item.tags || "",
                "CREATOR": item.ownerNm || "",
                "RESOLUTION": item.resolution || "-",
                "UPLOAD_DT": item.uploadDt || ""
            });
        }
        dlVersion.setJSON(rows);
        if (rows.length > 0) {
            scwin.loadAssetDetail(rows[0].ASSET_ID);
        } else {
            scwin._applyDetail(-1);
        }
    });
};

scwin.loadAssetDetail = function (assetId) {
    scwin.callApi("/api/dam/assets/" + assetId, function (response) {
        var asset = response.asset || {};
        var latestVersion = (response.versions && response.versions.length > 0) ? response.versions[0] : {};

        scwin._setVal("inp_versionFileName", asset.fileNm || "");
        scwin._setVal("sel_versionAssetType", asset.tags || "");
        scwin._setVal("sel_versionStatus", asset.status || "Draft");
        scwin._setVal("inp_versionCreator", asset.ownerNm || latestVersion.ownerNm || "");
        scwin._setVal("inp_versionResolution", asset.resolution || "-");
        scwin._setVal("inp_versionUploaded", asset.uploadDt || latestVersion.uploadDt || "");

        try {
            var img = $p.getComponentById("img_versionPreview");
            if (img && typeof img.setSrc === "function") {
                img.setSrc(asset.previewUrl || latestVersion.previewUrl || "/cm/dam/images/preview/document.svg");
            }
        } catch (e) {}
    });
};

scwin.grdVersion_onrowindexchange = function (gridObj, oldRowIndex, newRowIndex) {
    var row = dlVersion.getRowJSON(newRowIndex);
    if (row && row.ASSET_ID) {
        scwin.loadAssetDetail(row.ASSET_ID);
    } else {
        scwin._applyDetail(newRowIndex);
    }
};

scwin._setVal = function (id, val) {
    try {
        var c = $p.getComponentById(id);
        if (c && typeof c.setValue === "function") { c.setValue(val); }
    } catch (e) {}
};

scwin._applyDetail = function (rowIndex) {
    var row = dlVersion.getRowJSON(rowIndex);
    if (!row) {
        scwin._setVal("inp_versionFileName", "");
        scwin._setVal("sel_versionAssetType", "");
        scwin._setVal("sel_versionStatus", "Draft");
        scwin._setVal("inp_versionCreator", "");
        scwin._setVal("inp_versionResolution", "");
        scwin._setVal("inp_versionUploaded", "");
        return;
    }

    try {
        var img = $p.getComponentById("img_versionPreview");
        if (img && typeof img.setSrc === "function") {
            img.setSrc(row.PREVIEW_URL || "/cm/dam/images/preview/document.svg");
        }
    } catch (e) {}

    scwin._setVal("inp_versionFileName", row.FILE_NM || "");
    scwin._setVal("sel_versionAssetType", row.TAGS || "");
    scwin._setVal("sel_versionStatus", row.STATUS || "");
    scwin._setVal("inp_versionCreator", row.CREATOR || "");
    scwin._setVal("inp_versionResolution", row.RESOLUTION || "");
    scwin._setVal("inp_versionUploaded", row.UPLOAD_DT || "");
};

scwin.btn_versionDownload_onclick = function () { /* mock */ };
scwin.btn_versionEdit_onclick = function () { /* mock */ };
]]></script>
    </head>
    <body ev:onpageload="scwin.onpageload">
        <xf:group class="dam-page dam-asset-page">
            <w2:textbox class="dam-page-title" label="Version Control"/>

            <xf:group class="dam-asset-grid">
                <xf:group class="dam-asset-left">
                    <xf:group class="dam-asset-panel dam-asset-folder">
                        <xf:group class="dam-asset-panel-head">
                            <w2:textbox class="dam-asset-panel-title" label="Folder Structure" tagname="h3"/>
                            <xf:group class="dam-asset-panel-actions">
                                <xf:trigger class="dam-icon-btn" title="Sort">
                                    <xf:label><![CDATA[↑↓]]></xf:label>
                                </xf:trigger>
                                <xf:trigger class="dam-icon-btn" title="Refresh">
                                    <xf:label><![CDATA[⟳]]></xf:label>
                                </xf:trigger>
                            </xf:group>
                        </xf:group>
                        <xf:group class="dam-asset-folder-body">
                            <w2:treeview id="trvVersionFolder" class="dam-asset-tree" style="width:100%;height:100%;" dataType="listed" tooltipGroupClass="false">
                                <w2:node>
                                    <w2:label><![CDATA[Digital Assets]]></w2:label>
                                    <w2:value><![CDATA[1]]></w2:value>
                                    <w2:folder><![CDATA[true]]></w2:folder>
                                    <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                    <w2:node>
                                        <w2:label><![CDATA[Marketing Documents]]></w2:label>
                                        <w2:value><![CDATA[2]]></w2:value>
                                        <w2:folder><![CDATA[true]]></w2:folder>
                                        <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                        <w2:node>
                                            <w2:label><![CDATA[Campaign Banners]]></w2:label>
                                            <w2:value><![CDATA[3]]></w2:value>
                                            <w2:folder><![CDATA[true]]></w2:folder>
                                            <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                        </w2:node>
                                        <w2:node class="tree-pdf-node">
                                            <w2:label><![CDATA[PDF Brochures]]></w2:label>
                                            <w2:value><![CDATA[4]]></w2:value>
                                            <w2:folder><![CDATA[false]]></w2:folder>
                                            <w2:iconImage><![CDATA[/cm/images/base/ico_docu.png]]></w2:iconImage>
                                        </w2:node>
                                        <w2:node>
                                            <w2:label><![CDATA[Social Media Assets]]></w2:label>
                                            <w2:value><![CDATA[5]]></w2:value>
                                            <w2:folder><![CDATA[true]]></w2:folder>
                                            <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                        </w2:node>
                                    </w2:node>
                                    <w2:node>
                                        <w2:label><![CDATA[Video Assets]]></w2:label>
                                        <w2:value><![CDATA[6]]></w2:value>
                                        <w2:folder><![CDATA[true]]></w2:folder>
                                        <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                    </w2:node>
                                    <w2:node>
                                        <w2:label><![CDATA[Internal Manuals]]></w2:label>
                                        <w2:value><![CDATA[7]]></w2:value>
                                        <w2:folder><![CDATA[true]]></w2:folder>
                                        <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                    </w2:node>
                                </w2:node>
                            </w2:treeview>
                        </xf:group>
                    </xf:group>

                    <xf:group class="dam-asset-panel dam-asset-files">
                        <w2:tabControl id="tab_versionHistory" class="dam-version-tab" style="width:100%;height:100%;">
                            <w2:tabs id="tab_ver_main" label="Version History"></w2:tabs>
                            <w2:tabs id="tab_ver_compare" label="Chontiat History"></w2:tabs>
                            <w2:content id="cnt_ver_main">
                                <xf:group class="dam-asset-files-body" style="height:100%;">
                                    <xf:group class="dam-asset-panel-head">
                                        <xf:group class="dam-asset-panel-actions">
                                            <xf:trigger class="dam-icon-btn" title="Sort">
                                                <xf:label><![CDATA[⇅]]></xf:label>
                                            </xf:trigger>
                                            <xf:trigger class="dam-icon-btn" title="Filter">
                                                <xf:label><![CDATA[▽]]></xf:label>
                                            </xf:trigger>
                                        </xf:group>
                                    </xf:group>
                                    <w2:gridView id="grdVersion" class="dam-asset-grid-view" dataList="data:dlVersion" autoFit="allColumn" focusMode="row"
                                        style="width:100%;height:calc(100% - 76px);" ev:onrowindexchange="scwin.grdVersion_onrowindexchange">
                                        <w2:header>
                                            <w2:row>
                                                <w2:column id="hdVChk" inputType="checkbox" width="40" value=""/>
                                                <w2:column id="hdVIcon" inputType="text" width="70" value="Icon"/>
                                                <w2:column id="hdVName" inputType="text" width="240" value="Name"/>
                                                <w2:column id="hdVType" inputType="text" width="140" value="Type"/>
                                                <w2:column id="hdVSize" inputType="text" width="100" value="Size"/>
                                                <w2:column id="hdVStatus" inputType="text" width="120" value="Status"/>
                                            </w2:row>
                                        </w2:header>
                                        <w2:gBody>
                                            <w2:row>
                                                <w2:column id="CHK" inputType="checkbox" width="40" displayMode="always"/>
                                                <w2:column id="ICON" inputType="text" width="70" displayMode="label" class="dam-cell-icon"/>
                                                <w2:column id="FILE_NM" inputType="text" width="240" displayMode="label"/>
                                                <w2:column id="FILE_TYPE" inputType="text" width="140" displayMode="label"/>
                                                <w2:column id="FILE_SIZE" inputType="text" width="100" displayMode="label"/>
                                                <w2:column id="STATUS" inputType="text" width="120" displayMode="label" class="dam-cell-status"/>
                                            </w2:row>
                                        </w2:gBody>
                                    </w2:gridView>
                                    <xf:group class="dam-asset-pagination">
                                        <w2:textbox class="dam-pagi-label" label="Pagination"/>
                                        <xf:group class="dam-pagi-controls">
                                            <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[|<]]></xf:label></xf:trigger>
                                            <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[<]]></xf:label></xf:trigger>
                                            <xf:trigger class="dam-pagi-btn dam-pagi-active"><xf:label><![CDATA[1]]></xf:label></xf:trigger>
                                            <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[>]]></xf:label></xf:trigger>
                                            <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[>|]]></xf:label></xf:trigger>
                                        </xf:group>
                                    </xf:group>
                                </xf:group>
                            </w2:content>
                            <w2:content id="cnt_ver_compare">
                                <xf:group class="dam-asset-files-body" style="height:100%;padding:1rem;">
                                    <w2:textbox label="Chontiat History content (mock)" style="font-size:13px;color:#64748b;"/>
                                </xf:group>
                            </w2:content>
                        </w2:tabControl>
                    </xf:group>
                </xf:group>

                <xf:group class="dam-asset-right">
                    <xf:group class="dam-asset-panel dam-asset-detail">
                        <xf:group class="dam-asset-panel-head">
                            <w2:textbox class="dam-asset-panel-title" label="Asset Details Panel" tagname="h3"/>
                        </xf:group>

                        <xf:group class="dam-asset-preview">
                            <xf:image id="img_versionPreview" class="dam-asset-preview-img" src="/cm/dam/images/preview/image.svg"></xf:image>
                        </xf:group>

                        <xf:group class="dam-form-row">
                            <w2:textbox class="dam-form-label" label="File Name"/>
                            <w2:input id="inp_versionFileName" class="dam-form-input"/>
                        </xf:group>

                        <xf:group class="dam-form-row">
                            <w2:textbox class="dam-form-label" label="Asset Type"/>
                            <xf:select id="sel_versionAssetType" appearance="checkcombobox" class="dam-form-chips" renderType="component" style="width:100%;">
                                <xf:choices>
                                    <xf:item><xf:label>CheckComboBox</xf:label><xf:value>CheckComboBox</xf:value></xf:item>
                                    <xf:item><xf:label>tags</xf:label><xf:value>tags</xf:value></xf:item>
                                    <xf:item><xf:label>asset</xf:label><xf:value>asset</xf:value></xf:item>
                                </xf:choices>
                            </xf:select>
                        </xf:group>

                        <xf:group class="dam-form-row">
                            <w2:textbox class="dam-form-label" label="Status"/>
                            <xf:select1 id="sel_versionStatus" appearance="minimal" class="dam-form-select" renderType="select" style="width:100%;">
                                <xf:item><xf:label>Published</xf:label><xf:value>Published</xf:value></xf:item>
                                <xf:item><xf:label>Draft</xf:label><xf:value>Draft</xf:value></xf:item>
                                <xf:item><xf:label>Archived</xf:label><xf:value>Archived</xf:value></xf:item>
                            </xf:select1>
                        </xf:group>

                        <xf:group class="dam-form-actions">
                            <xf:trigger id="btn_versionDownload" class="dam-btn-outline" ev:onclick="scwin.btn_versionDownload_onclick">
                                <xf:label><![CDATA[↓ Download]]></xf:label>
                            </xf:trigger>
                            <xf:trigger id="btn_versionEdit" class="dam-btn-primary" ev:onclick="scwin.btn_versionEdit_onclick">
                                <xf:label><![CDATA[Edit Metadata]]></xf:label>
                            </xf:trigger>
                        </xf:group>

                        <xf:group class="dam-meta-section">
                            <w2:textbox class="dam-meta-title" label="Metadata" tagname="h4"/>
                            <xf:group class="dam-form-row">
                                <w2:textbox class="dam-form-label" label="Creator"/>
                                <w2:input id="inp_versionCreator" class="dam-form-input" readOnly="true"/>
                            </xf:group>
                            <xf:group class="dam-form-row">
                                <w2:textbox class="dam-form-label" label="Resolution"/>
                                <w2:input id="inp_versionResolution" class="dam-form-input" readOnly="true"/>
                            </xf:group>
                            <xf:group class="dam-form-row">
                                <w2:textbox class="dam-form-label" label="Uploaded Date"/>
                                <w2:input id="inp_versionUploaded" class="dam-form-input" readOnly="true"/>
                            </xf:group>
                        </xf:group>
                    </xf:group>
                </xf:group>
            </xf:group>
        </xf:group>
    </body>
</html>
