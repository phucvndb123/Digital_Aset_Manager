<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/cm/css/base.css" type="text/css"?>
<?xml-stylesheet href="/cm/dam/css/dam.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare"
    xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate/>
        <w2:MSA/>
        <xf:model>
            <w2:dataCollection baseNode="map">
                <w2:dataList id="dlAsset" baseNode="list" repeatNode="map">
                    <w2:columnInfo>
                        <w2:column id="CHK" name="CHK" dataType="text" />
                        <w2:column id="ICON" name="ICON" dataType="text" />
                        <w2:column id="FILE_NM" name="FILE_NM" dataType="text" />
                        <w2:column id="FILE_TYPE" name="FILE_TYPE" dataType="text" />
                        <w2:column id="FILE_SIZE" name="FILE_SIZE" dataType="text" />
                        <w2:column id="STATUS" name="STATUS" dataType="text" />
                        <w2:column id="TAGS" name="TAGS" dataType="text" />
                        <w2:column id="CREATOR" name="CREATOR" dataType="text" />
                        <w2:column id="RESOLUTION" name="RESOLUTION" dataType="text" />
                        <w2:column id="UPLOAD_DT" name="UPLOAD_DT" dataType="text" />
                        <w2:column id="PREVIEW_URL" name="PREVIEW_URL" dataType="text" />
                    </w2:columnInfo>
                </w2:dataList>
            </w2:dataCollection>
            <w2:workflowCollection/>
        </xf:model>
        <w2:layoutInfo/>
        <w2:publicInfo method=""/>
        <script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function () {
    window.setTimeout(function () { scwin._initMockData(); }, 50);
};

scwin._initMockData = function () {
    var rows = [
        {
            "CHK": "", "ICON": "PDF",
            "FILE_NM": "File Name I Image",
            "FILE_TYPE": "Documents",
            "FILE_SIZE": "23 KB",
            "STATUS": "Draft",
            "TAGS": "",
            "CREATOR": "Creator",
            "RESOLUTION": "-",
            "UPLOAD_DT": "18/13/2023",
            "PREVIEW_URL": "/cm/dam/images/preview/document.svg"
        },
        {
            "CHK": "", "ICON": "JPG",
            "FILE_NM": "Product Image.jpg",
            "FILE_TYPE": "JPG",
            "FILE_SIZE": "3.00 GB",
            "STATUS": "Published",
            "TAGS": "CheckComboBox,tags",
            "CREATOR": "Creator",
            "RESOLUTION": "1950 x 650",
            "UPLOAD_DT": "18/13/2023",
            "PREVIEW_URL": "/cm/dam/images/preview/image.svg"
        },
        {
            "CHK": "", "ICON": "MP4",
            "FILE_NM": "Video Assets",
            "FILE_TYPE": "MP4 Asset",
            "FILE_SIZE": "6.80 KB",
            "STATUS": "Published",
            "TAGS": "",
            "CREATOR": "Creator",
            "RESOLUTION": "-",
            "UPLOAD_DT": "18/13/2023",
            "PREVIEW_URL": "/cm/dam/images/preview/video.svg"
        },
        {
            "CHK": "", "ICON": "MP4",
            "FILE_NM": "Internal Manuals",
            "FILE_TYPE": "MP4 Asset",
            "FILE_SIZE": "3.17 KB",
            "STATUS": "Published",
            "TAGS": "",
            "CREATOR": "Creator",
            "RESOLUTION": "-",
            "UPLOAD_DT": "18/13/2023",
            "PREVIEW_URL": "/cm/dam/images/preview/video.svg"
        }
    ];

    try { dlAsset.setJSON(rows); } catch (e) { console.warn("[Asset] setJSON failed", e); }

    try {
        var tv = $p.getComponentById("trvFolder");
        if (tv && typeof tv.expandAll === "function") { tv.expandAll(); }
    } catch (e) { console.warn("[Asset] expandAll failed", e); }

    scwin._applyDetail(1);
    window.setTimeout(function () { scwin._refreshGridStyling(); }, 100);
    window.setTimeout(function () { scwin._refreshGridStyling(); }, 500);
    window.setTimeout(function () { scwin._refreshGridStyling(); }, 1500);
};

scwin.grdAsset_onrowindexchange = function (gridObj, oldRowIndex, newRowIndex) {
    scwin._applyDetail(newRowIndex);
};

scwin._BADGE_COLORS = {
    "PDF": "#dc2626",
    "JPG": "#16a34a",
    "JPEG": "#16a34a",
    "PNG": "#2563eb",
    "MP4": "#ea580c",
    "DOC": "#2563eb",
    "DOCX": "#2563eb",
    "GIF": "#9333ea"
};

scwin._styleIconBadges = function () {
    try {
        var colors = scwin._BADGE_COLORS;
        var cells = document.querySelectorAll(".dam-asset-grid-view .dam-cell-icon");
        for (var i = 0; i < cells.length; i++) {
            var cell = cells[i];
            var txt = (cell.textContent || "").trim().toUpperCase();
            var bg = colors[txt];
            if (!bg) { continue; }
            cell.style.cssText = "padding:4px 0 !important;text-align:center !important;font-weight:normal !important;";
            var badge = cell.querySelector(".dam-badge-injected");
            if (!badge) {
                badge = document.createElement("span");
                badge.className = "dam-badge-injected";
                cell.innerHTML = "";
                cell.appendChild(badge);
            }
            badge.textContent = txt;
            badge.style.cssText = "display:inline-block !important;padding:3px 8px !important;background:" + bg + " !important;color:#fff !important;border-radius:3px !important;font-weight:700 !important;font-size:0.7rem !important;letter-spacing:0.02em !important;line-height:1.4 !important;min-width:30px !important;text-align:center !important;box-shadow:0 1px 2px rgba(0,0,0,0.15) !important;";
        }
    } catch (e) { /* ignore */ }
};

scwin._refreshGridStyling = function () {
    scwin._styleIconBadges();
};

scwin.grdAsset_ondrawendrow = function () {
    scwin._refreshGridStyling();
};

scwin._setVal = function (id, val) {
    try {
        var c = $p.getComponentById(id);
        if (c && typeof c.setValue === "function") { c.setValue(val); }
    } catch (e) {}
};

scwin._applyDetail = function (rowIndex) {
    var row = dlAsset.getRowJSON(rowIndex);
    if (!row) { return; }
    try {
        var img = $p.getComponentById("img_preview");
        if (img && typeof img.setSrc === "function") {
            img.setSrc(row.PREVIEW_URL || "/cm/dam/images/preview/document.svg");
        }
    } catch (e) {}
    scwin._setVal("inp_fileName", row.FILE_NM || "");
    scwin._setVal("sel_assetType", row.TAGS || "");
    scwin._setVal("sel_status", row.STATUS || "");
    scwin._setVal("inp_creator", row.CREATOR || "");
    scwin._setVal("inp_resolution", row.RESOLUTION || "");
    scwin._setVal("inp_uploaded", row.UPLOAD_DT || "");
};

scwin.btn_download_onclick = function () { /* mock */ };
scwin.btn_edit_onclick     = function () { /* mock */ };
]]></script>
    </head>
    <body ev:onpageload="scwin.onpageload">
        <xf:group class="dam-page dam-asset-page">

            <xf:group class="dam-asset-grid">

                <!-- LEFT COLUMN -->
                <xf:group class="dam-asset-left">

                    <!-- Folder Structure -->
                    <xf:group class="dam-asset-panel dam-asset-folder">
                        <xf:group class="dam-asset-panel-head">
                            <w2:textbox class="dam-asset-panel-title" label="Folder Structure" tagname="h3" />
                            <xf:group class="dam-asset-panel-actions">
                                <xf:trigger id="btn_folderSort" class="dam-icon-btn" title="Sort">
                                    <xf:label><![CDATA[↑↓]]></xf:label>
                                </xf:trigger>
                                <xf:trigger id="btn_folderRefresh" class="dam-icon-btn" title="Refresh">
                                    <xf:label><![CDATA[⟳]]></xf:label>
                                </xf:trigger>
                            </xf:group>
                        </xf:group>
                        <xf:group class="dam-asset-folder-body">
                            <w2:treeview id="trvFolder" class="dam-asset-tree" style="width:100%;height:100%;" dataType="listed" tooltipGroupClass="false">
                                <w2:node>
                                    <w2:label><![CDATA[Digital Assets]]></w2:label>
                                    <w2:value><![CDATA[1]]></w2:value>
                                    <w2:folder><![CDATA[true]]></w2:folder>
                                    <w2:node>
                                        <w2:label><![CDATA[Marketing Documents]]></w2:label>
                                        <w2:value><![CDATA[2]]></w2:value>
                                        <w2:folder><![CDATA[true]]></w2:folder>
                                        <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                        <w2:node>
                                            <w2:label><![CDATA[Campaign Banners]]></w2:label>
                                            <w2:value><![CDATA[3]]></w2:value>
                                            <w2:folder><![CDATA[true]]></w2:folder>
                                            <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                        </w2:node>
                                        <w2:node class="tree-pdf-node">
                                            <w2:label><![CDATA[PDF Brochures]]></w2:label>
                                            <w2:value><![CDATA[4]]></w2:value>
                                            <w2:folder><![CDATA[false]]></w2:folder>
                                            <w2:iconImage><![CDATA[/cm/images/base/ico_docu.png]]></w2:iconImage>
                                        </w2:node>
                                        <w2:node>
                                            <w2:label><![CDATA[Social Media Assets]]></w2:label>
                                            <w2:value><![CDATA[5]]></w2:value>
                                            <w2:folder><![CDATA[true]]></w2:folder>
                                            <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                        </w2:node>
                                    </w2:node>
                                    <w2:node>
                                        <w2:label><![CDATA[Video Assets]]></w2:label>
                                        <w2:value><![CDATA[6]]></w2:value>
                                        <w2:folder><![CDATA[true]]></w2:folder>
                                        <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                    </w2:node>
                                    <w2:node>
                                        <w2:label><![CDATA[Internal Manuals]]></w2:label>
                                        <w2:value><![CDATA[7]]></w2:value>
                                        <w2:folder><![CDATA[true]]></w2:folder>
                                        <w2:iconImage><![CDATA[/cm/images/base/ico_ds_tree.png]]></w2:iconImage>
                                    </w2:node>
                                </w2:node>
                            </w2:treeview>
                        </xf:group>
                    </xf:group>

                    <!-- File List -->
                    <xf:group class="dam-asset-panel dam-asset-files">
                        <xf:group class="dam-asset-panel-head">
                            <w2:textbox class="dam-asset-panel-title" label="File List" tagname="h3" />
                            <xf:group class="dam-asset-panel-actions">
                                <xf:trigger id="btn_filesSort" class="dam-icon-btn" title="Sort">
                                    <xf:label><![CDATA[↑↓]]></xf:label>
                                </xf:trigger>
                                <xf:trigger id="btn_filesFilter" class="dam-icon-btn" title="Filter">
                                    <xf:label><![CDATA[▽]]></xf:label>
                                </xf:trigger>
                            </xf:group>
                        </xf:group>
                        <xf:group class="dam-asset-files-body">
                            <w2:gridView id="grdAsset" class="dam-asset-grid-view" dataList="data:dlAsset" autoFit="allColumn" focusMode="row"
                                style="width:100%;height:calc(100% - 38px);" useSort="true"
                                ev:onrowindexchange="scwin.grdAsset_onrowindexchange"
                                ev:ondrawendrow="scwin.grdAsset_ondrawendrow">
                                <w2:header>
                                    <w2:row>
                                        <w2:column id="hdChk" inputType="checkbox" width="40" value="" />
                                        <w2:column id="hdIcon" inputType="text" width="70" value="Icon" />
                                        <w2:column id="hdFileNm" inputType="text" width="240" value="Name" sortable="true" />
                                        <w2:column id="hdType" inputType="text" width="140" value="Type" sortable="true" />
                                        <w2:column id="hdSize" inputType="text" width="100" value="Size" sortable="true" />
                                        <w2:column id="hdStatus" inputType="text" width="120" value="Status" sortable="true" />
                                    </w2:row>
                                </w2:header>
                                <w2:gBody>
                                    <w2:row>
                                        <w2:column id="CHK" inputType="checkbox" width="40" displayMode="always" />
                                        <w2:column id="ICON" inputType="text" width="70" displayMode="label" class="dam-cell-icon" />
                                        <w2:column id="FILE_NM" inputType="text" width="240" displayMode="label" />
                                        <w2:column id="FILE_TYPE" inputType="text" width="140" displayMode="label" />
                                        <w2:column id="FILE_SIZE" inputType="text" width="100" displayMode="label" />
                                        <w2:column id="STATUS" inputType="text" width="120" displayMode="label" class="dam-cell-status" />
                                    </w2:row>
                                </w2:gBody>
                            </w2:gridView>
                            <xf:group class="dam-asset-pagination">
                                <w2:textbox class="dam-pagi-label" label="Pagination" />
                                <xf:group class="dam-pagi-controls">
                                    <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[|<]]></xf:label></xf:trigger>
                                    <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[<]]></xf:label></xf:trigger>
                                    <xf:trigger class="dam-pagi-btn dam-pagi-active"><xf:label><![CDATA[1]]></xf:label></xf:trigger>
                                    <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[>]]></xf:label></xf:trigger>
                                    <xf:trigger class="dam-pagi-btn"><xf:label><![CDATA[>|]]></xf:label></xf:trigger>
                                </xf:group>
                            </xf:group>
                        </xf:group>
                    </xf:group>

                </xf:group>

                <!-- RIGHT COLUMN -->
                <xf:group class="dam-asset-right">
                    <xf:group class="dam-asset-panel dam-asset-detail">
                        <xf:group class="dam-asset-panel-head">
                            <w2:textbox class="dam-asset-panel-title" label="Asset Details Panel" tagname="h3" />
                        </xf:group>

                        <xf:group class="dam-asset-preview">
                            <xf:image id="img_preview" class="dam-asset-preview-img" src="/cm/dam/images/preview/image.svg"></xf:image>
                        </xf:group>

                        <xf:group class="dam-form-row">
                            <w2:textbox class="dam-form-label" label="File Name" />
                            <w2:input id="inp_fileName" class="dam-form-input" />
                        </xf:group>

                        <xf:group class="dam-form-row">
                            <w2:textbox class="dam-form-label" label="Asset Type" />
                            <xf:select id="sel_assetType" appearance="checkcombobox" class="dam-form-chips" renderType="component" style="width:100%;">
                                <xf:choices>
                                    <xf:item><xf:label>CheckComboBox</xf:label><xf:value>CheckComboBox</xf:value></xf:item>
                                    <xf:item><xf:label>tags</xf:label><xf:value>tags</xf:value></xf:item>
                                    <xf:item><xf:label>asset</xf:label><xf:value>asset</xf:value></xf:item>
                                </xf:choices>
                            </xf:select>
                        </xf:group>

                        <xf:group class="dam-form-row">
                            <w2:textbox class="dam-form-label" label="Status" />
                            <xf:select1 id="sel_status" appearance="minimal" class="dam-form-select" renderType="select" style="width:100%;">
                                <xf:item><xf:label>Published</xf:label><xf:value>Published</xf:value></xf:item>
                                <xf:item><xf:label>Draft</xf:label><xf:value>Draft</xf:value></xf:item>
                                <xf:item><xf:label>Archived</xf:label><xf:value>Archived</xf:value></xf:item>
                            </xf:select1>
                        </xf:group>

                        <xf:group class="dam-form-actions">
                            <xf:trigger id="btn_download" class="dam-btn-outline" ev:onclick="scwin.btn_download_onclick">
                                <xf:label><![CDATA[⬇ Download]]></xf:label>
                            </xf:trigger>
                            <xf:trigger id="btn_edit" class="dam-btn-primary" ev:onclick="scwin.btn_edit_onclick">
                                <xf:label><![CDATA[Edit Metadata]]></xf:label>
                            </xf:trigger>
                        </xf:group>

                        <xf:group class="dam-meta-section">
                            <w2:textbox class="dam-meta-title" label="Metadata" tagname="h4" />

                            <xf:group class="dam-form-row">
                                <w2:textbox class="dam-form-label" label="Creator" />
                                <w2:input id="inp_creator" class="dam-form-input" readOnly="true" />
                            </xf:group>

                            <xf:group class="dam-form-row">
                                <w2:textbox class="dam-form-label" label="Resolution" />
                                <w2:input id="inp_resolution" class="dam-form-input" readOnly="true" />
                            </xf:group>

                            <xf:group class="dam-form-row">
                                <w2:textbox class="dam-form-label" label="Uploaded Date" />
                                <w2:input id="inp_uploaded" class="dam-form-input" readOnly="true" />
                            </xf:group>
                        </xf:group>
                    </xf:group>
                </xf:group>

            </xf:group>
        </xf:group>
    </body>
</html>
