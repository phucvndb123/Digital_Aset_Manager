<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="/cm/css/base.css" type="text/css"?>
<?xml-stylesheet href="/cm/dam/css/dam.css" type="text/css"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare"
    xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate/>
        <w2:MSA/>
        <xf:model>
            <w2:dataCollection baseNode="map">
                <w2:dataList id="dlVersions" baseNode="list" repeatNode="map">
                    <w2:columnInfo>
                        <w2:column id="VER_ID" name="VER_ID" dataType="text"/>
                        <w2:column id="VER_NO" name="VER_NO" dataType="text"/>
                        <w2:column id="FILE_NM" name="FILE_NM" dataType="text"/>
                        <w2:column id="UPLOAD_DT" name="UPLOAD_DT" dataType="text"/>
                        <w2:column id="OWNER_NM" name="OWNER_NM" dataType="text"/>
                        <w2:column id="FILE_URL" name="FILE_URL" dataType="text"/>
                    </w2:columnInfo>
                </w2:dataList>
                <w2:dataList id="dlAccessLogs" baseNode="list" repeatNode="map">
                    <w2:columnInfo>
                        <w2:column id="ACTION_DT" name="ACTION_DT" dataType="text"/>
                        <w2:column id="USER_NM" name="USER_NM" dataType="text"/>
                        <w2:column id="ACTION_TP" name="ACTION_TP" dataType="text"/>
                        <w2:column id="REMARK" name="REMARK" dataType="text"/>
                    </w2:columnInfo>
                </w2:dataList>
            </w2:dataCollection>
            <w2:workflowCollection/>
        </xf:model>
        <w2:layoutInfo/>
        <w2:publicInfo method=""/>
        <script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function () {
    scwin._init();
};

scwin._getParam = function () {
    try { return $p.getParameter("paramData") || {}; } catch (e) { return {}; }
};

scwin._callApi = function (method, url, callback) {
    var xhr = new XMLHttpRequest();
    xhr.open(method, url, true);
    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded; charset=UTF-8");
    xhr.onreadystatechange = function () {
        if (xhr.readyState === 4) {
            if (xhr.status >= 200 && xhr.status < 300) {
                callback(JSON.parse(xhr.responseText || "{}"));
            }
        }
    };
    xhr.send(method === "POST" ? "" : null);
};

scwin._init = function () {
    var p = scwin._getParam();
    scwin.assetId = p.assetId;
    if (!scwin.assetId) {
        dlVersions.setJSON([]);
        dlAccessLogs.setJSON([]);
        return;
    }

    scwin._loadAsset(scwin.assetId);
    scwin._loadAccessLogs(scwin.assetId);

    try {
        var grid = $p.getComponentById("grd_versions");
        if (grid && typeof grid.bind === "function") {
            grid.bind("oncellclick", scwin._onVersionCellClick);
        }
    } catch (e) {}
};

scwin._loadAsset = function (assetId) {
    scwin._callApi("GET", "/api/dam/assets/" + assetId, function (res) {
        var asset = res.asset || {};
        var versions = res.versions || [];
        dlVersions.setJSON(versions);

        try {
            var img = $p.getComponentById("img_preview_popup");
            if (img && typeof img.setSrc === "function") {
                img.setSrc(asset.previewUrl || "/cm/dam/images/preview/document.svg");
            }
        } catch (e) {}
    });
};

scwin._loadAccessLogs = function (assetId) {
    scwin._callApi("GET", "/api/dam/assets/" + assetId + "/access-logs", function (list) {
        dlAccessLogs.setJSON(list || []);
    });
};

scwin._onVersionCellClick = function (row, col) {
    try {
        var grid = $p.getComponentById("grd_versions");
        var colId = grid.getColumnID(col);
        var realRow = grid.getRealRowIndex(row);
        var rowData = dlVersions.getRowJSON(realRow);
        if (!rowData) { return; }

        if (colId === "BTN_DOWNLOAD") {
            // demo: open file url in new window if exists
            if (rowData.fileUrl) {
                window.open(rowData.fileUrl, "_blank");
            }
        } else if (colId === "BTN_RESTORE") {
            scwin._restoreVersion(rowData.verId);
        }
    } catch (e) {}
};

scwin._restoreVersion = function (verId) {
    if (!scwin.assetId || !verId) { return; }
    var url = "/api/dam/assets/" + scwin.assetId + "/restore?verId=" + encodeURIComponent(verId) + "&userNm=" + encodeURIComponent("SYSTEM");
    scwin._callApi("POST", url, function () {
        scwin._loadAccessLogs(scwin.assetId);
    });
};
]]></script>
    </head>
    <body ev:onpageload="scwin.onpageload">
        <xf:group class="dam-page dam-asset-page" style="padding:1rem;">
            <xf:group class="dam-asset-grid" style="grid-template-columns:minmax(0, 1fr) 420px;">
                <xf:group class="dam-asset-left">
                    <xf:group class="dam-asset-panel dam-asset-files" style="height:100%;">
                        <w2:tabControl id="tab_vc_popup" class="dam-version-tab" style="width:100%;height:100%;">
                            <w2:tabs id="tab_vh" label="Version History"></w2:tabs>
                            <w2:tabs id="tab_al" label="Access Logs"></w2:tabs>

                            <w2:content id="cnt_vh">
                                <xf:group class="dam-asset-files-body" style="height:100%;padding-top:0.5rem;">
                                    <w2:gridView id="grd_versions" class="dam-asset-grid-view" dataList="data:dlVersions" autoFit="allColumn" focusMode="row"
                                        style="width:100%;height:100%;">
                                        <w2:header>
                                            <w2:row>
                                                <w2:column id="hdVerNo" inputType="text" width="110" value="Version"/>
                                                <w2:column id="hdFileNm" inputType="text" width="260" value="File Name"/>
                                                <w2:column id="hdUploadDt" inputType="text" width="170" value="Uploaded Date"/>
                                                <w2:column id="hdOwner" inputType="text" width="120" value="Uploader"/>
                                                <w2:column id="hdActDn" inputType="text" width="110" value="Download"/>
                                                <w2:column id="hdActRs" inputType="text" width="110" value="Restore"/>
                                            </w2:row>
                                        </w2:header>
                                        <w2:gBody>
                                            <w2:row>
                                                <w2:column id="verNo" inputType="text" width="110" displayMode="label"/>
                                                <w2:column id="fileNm" inputType="text" width="260" displayMode="label"/>
                                                <w2:column id="uploadDt" inputType="text" width="170" displayMode="label"/>
                                                <w2:column id="ownerNm" inputType="text" width="120" displayMode="label"/>
                                                <w2:column id="BTN_DOWNLOAD" inputType="button" width="110" value="Download"/>
                                                <w2:column id="BTN_RESTORE" inputType="button" width="110" value="Restore"/>
                                            </w2:row>
                                        </w2:gBody>
                                    </w2:gridView>
                                </xf:group>
                            </w2:content>

                            <w2:content id="cnt_al">
                                <xf:group class="dam-asset-files-body" style="height:100%;padding-top:0.5rem;">
                                    <w2:gridView id="grd_access" class="dam-asset-grid-view" dataList="data:dlAccessLogs" autoFit="allColumn" focusMode="row"
                                        style="width:100%;height:100%;">
                                        <w2:header>
                                            <w2:row>
                                                <w2:column id="hdADt" inputType="text" width="180" value="Date"/>
                                                <w2:column id="hdUser" inputType="text" width="120" value="User"/>
                                                <w2:column id="hdAct" inputType="text" width="120" value="Action"/>
                                                <w2:column id="hdRemark" inputType="text" width="300" value="Remark"/>
                                            </w2:row>
                                        </w2:header>
                                        <w2:gBody>
                                            <w2:row>
                                                <w2:column id="actionDt" inputType="text" width="180" displayMode="label"/>
                                                <w2:column id="userNm" inputType="text" width="120" displayMode="label"/>
                                                <w2:column id="actionTp" inputType="text" width="120" displayMode="label"/>
                                                <w2:column id="remark" inputType="text" width="300" displayMode="label"/>
                                            </w2:row>
                                        </w2:gBody>
                                    </w2:gridView>
                                </xf:group>
                            </w2:content>
                        </w2:tabControl>
                    </xf:group>
                </xf:group>

                <xf:group class="dam-asset-right">
                    <xf:group class="dam-asset-panel dam-asset-detail">
                        <xf:group class="dam-asset-panel-head">
                            <w2:textbox class="dam-asset-panel-title" label="Preview" tagname="h3"/>
                        </xf:group>
                        <xf:group class="dam-asset-preview" style="height:260px;">
                            <xf:image id="img_preview_popup" class="dam-asset-preview-img" src="/cm/dam/images/preview/image.svg"></xf:image>
                        </xf:group>
                    </xf:group>
                </xf:group>
            </xf:group>
        </xf:group>
    </body>
</html>

